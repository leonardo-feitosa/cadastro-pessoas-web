@model CadastroPessoasWeb.Models.Person
@{
    ViewData["Title"] = "Detalhes";
}

<h2>Detalhes</h2>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Idade</dt>
    <dd class="col-sm-10">@Model.Age</dd>

    <dt class="col-sm-2">Sexo</dt>
    <dd class="col-sm-10">@Model.Sex</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Voltar</a>