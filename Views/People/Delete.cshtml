@model CadastroPessoasWeb.Models.Person
@{
    ViewData["Title"] = "Excluir";
}

<h2>Excluir</h2>

<p>Tem certeza que deseja excluir esta pessoa?</p>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Idade</dt>
    <dd class="col-sm-10">@Model.Age</dd>

    <dt class="col-sm-2">Sexo</dt>
    <dd class="col-sm-10">@Model.Sex</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>